<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="535.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.algoritmosclasicosproyecto.controladores.RutasController">
    <children>
        <HBox layoutX="14.0" layoutY="14.0" prefHeight="500.0" prefWidth="920.0" spacing="20.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
            <children>
                <VBox prefWidth="300.0" spacing="12.0">
                    <children>
                        <Label text="Gestión de Rutas">
                            <font><Font name="Consolas Bold" size="24.0" /></font>
                        </Label>

                        <Label text="Origen:" />
                        <ComboBox fx:id="cmbOrigen" prefWidth="300.0" promptText="Seleccione parada de origen..." />

                        <Label text="Destino:" />
                        <ComboBox fx:id="cmbDestino" prefWidth="300.0" promptText="Seleccione parada de destino..." />

                        <HBox spacing="10.0">
                            <children>
                                <VBox prefWidth="145.0">
                                    <children>
                                        <Label text="Tiempo (min):" />
                                        <TextField fx:id="txtTiempo" promptText="Ej: 15.5" />
                                    </children>
                                </VBox>
                                <VBox prefWidth="145.0">
                                    <children>
                                        <Label text="Distancia (km):" />
                                        <TextField fx:id="txtDistancia" promptText="Ej: 5.2" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <Label text="Costo (RD$):" />
                        <TextField fx:id="txtCosto" promptText="Ej: 35.0" />

                        <CheckBox fx:id="chkTrasbordo" mnemonicParsing="false" text="Requiere Trasbordo" />

                        <HBox spacing="10.0">
                            <children>
                                <Button fx:id="btnAgregar" mnemonicParsing="false" onAction="#agregarRuta" prefWidth="145.0" style="-fx-background-color: #088395;" text="Agregar" textFill="WHITE">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>
                                <Button fx:id="btnEditar" disable="true" mnemonicParsing="false" onAction="#editarRuta" prefWidth="145.0" style="-fx-background-color: #f0ad4e;" text="Editar" textFill="WHITE">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>
                            </children>
                        </HBox>

                        <Button fx:id="btnEliminar" disable="true" mnemonicParsing="false" onAction="#eliminarRuta" prefWidth="300.0" style="-fx-background-color: #d9534f;" text="Eliminar Ruta" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#limpiarFormularioAction" prefWidth="300.0" text="Limpiar / Nueva Selección" />
                    </children>
                </VBox>

                <TableView fx:id="tablaRutas" prefHeight="500.0" prefWidth="600.0" HBox.hgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colOrigen" prefWidth="120.0" text="Origen" />
                        <TableColumn fx:id="colDestino" prefWidth="120.0" text="Destino" />
                        <TableColumn fx:id="colTiempo" prefWidth="80.0" text="Min" />
                        <TableColumn fx:id="colDistancia" prefWidth="80.0" text="Km" />
                        <TableColumn fx:id="colCosto" prefWidth="80.0" text="RD$" />
                        <TableColumn fx:id="colTrasbordo" prefWidth="90.0" text="Trasbordo" />
                    </columns>
                </TableView>
            </children>
        </HBox>
    </children>
</AnchorPane>