<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="857.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.algoritmosclasicosproyecto.controladores.MapaController">
    <children>
        <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Pane fx:id="paneMapa" prefHeight="520.0" prefWidth="818.0" VBox.vgrow="ALWAYS" />

                <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-width: 1 0 0 0;">
                    <padding>
                        <Insets left="20.0" right="20.0" />
                    </padding>
                    <children>
                        <VBox alignment="CENTER_LEFT" spacing="5.0">
                            <children>
                                <Label text="Origen:"><font><Font name="System Bold" size="12.0" /></font></Label>
                                <ComboBox fx:id="cmbOrigen" prefWidth="150.0" promptText="Origen" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER_LEFT" spacing="5.0">
                            <children>
                                <Label text="Destino:"><font><Font name="System Bold" size="12.0" /></font></Label>
                                <ComboBox fx:id="cmbDestino" prefWidth="150.0" promptText="Destino" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER_LEFT" spacing="5.0">
                            <children>
                                <Label text="Priorizar:"><font><Font name="System Bold" size="12.0" /></font></Label>
                                <ComboBox fx:id="cmbCriterio" prefWidth="130.0" />
                            </children>
                        </VBox>
                        <Button mnemonicParsing="false" onAction="#best_ruta" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #62529C; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Calcular Ruta">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Button>
                        <VBox alignment="CENTER_LEFT" prefHeight="79.0" prefWidth="188.0" HBox.hgrow="ALWAYS">
                     <children>
                              <Button mnemonicParsing="false" onAction="#limpiarBusqueda" prefHeight="40.0" prefWidth="104.0" style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Limpiar">
                                  <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                              </Button>
                     </children></VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
