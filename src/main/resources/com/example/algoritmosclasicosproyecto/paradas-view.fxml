<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #F4F4F4;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.algoritmosclasicosproyecto.controladores.ParadasController">
    <children>
        <VBox layoutX="20.0" layoutY="20.0" spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0"
              AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>

                <Label text="Gestión de Paradas" textFill="#3f326d">
                    <font>
                        <Font name="Consolas Bold" size="24.0"/>
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0"/>
                    </VBox.margin>
                </Label>

                <VBox style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-padding: 20;">
                    <children>
                        <GridPane hgap="15.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="NEVER" minWidth="10.0" prefWidth="120.0"/>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="200.0"/>
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                            </rowConstraints>
                            <children>

                                <Label text="Nombre:" GridPane.rowIndex="2">
                                    <font>
                                        <Font name="System Bold" size="14.0"/>
                                    </font>
                                </Label>
                                <TextField fx:id="txtNombre" promptText="Ej: Monumento a los Héroes"
                                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                <TextField fx:id="txtId" promptText="Identificador numérico" GridPane.columnIndex="1"/>
                                <Label prefHeight="20.0" prefWidth="97.0" text="ID:">
                                    <font>
                                        <Font name="System Bold" size="14.0"/>
                                    </font>
                                </Label>
                            </children>
                            <VBox.margin>
                                <Insets bottom="20.0"/>
                            </VBox.margin>
                        </GridPane>

                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <Button fx:id="btnAgregar" mnemonicParsing="false" onAction="#agregarParada"
                                        prefHeight="35.0" prefWidth="120.0"
                                        style="-fx-background-color: #088395; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"
                                        text="Agregar">
                                    <font>
                                        <Font name="System Bold" size="14.0"/>
                                    </font>
                                </Button>
                                <Button fx:id="btnEditar" mnemonicParsing="false" onAction="#editarParada"
                                        prefHeight="35.0" prefWidth="120.0"
                                        style="-fx-background-color: #f0ad4e; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"
                                        text="Editar">
                                    <font>
                                        <Font name="System Bold" size="14.0"/>
                                    </font>
                                </Button>
                                <Button fx:id="btnEliminar" mnemonicParsing="false" onAction="#eliminarParada"
                                        prefHeight="35.0" prefWidth="120.0"
                                        style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"
                                        text="Eliminar">
                                    <font>
                                        <Font name="System Bold" size="14.0"/>
                                    </font>
                                </Button>
                                <HBox HBox.hgrow="ALWAYS"/>
                                <Button mnemonicParsing="false" onAction="#limpiarFormulario" prefHeight="35.0"
                                        style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"
                                        text="Limpiar / Nueva Selección">
                                    <font>
                                        <Font name="System Bold" size="13.0"/>
                                    </font>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <TableView fx:id="tablaParadas"
                           style="-fx-border-color: #E0E0E0; -fx-border-radius: 5; -fx-background-radius: 5;"
                           VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" editable="false" maxWidth="200.0" minWidth="100.0" prefWidth="150.0"
                                     resizable="false" text="ID"/>
                        <TableColumn fx:id="colNombre" editable="false" minWidth="200.0" prefWidth="550.0"
                                     text="Nombre"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

            </children>
        </VBox>
    </children>
</AnchorPane>
