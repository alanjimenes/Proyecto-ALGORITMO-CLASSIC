<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="535.0" prefWidth="800.0"  xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.algoritmosclasicosproyecto.controladores.ParadasController">
    <children>
        <HBox layoutX="14.0" layoutY="14.0" prefHeight="500.0" prefWidth="770.0" spacing="20.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
            <children>
                <VBox prefWidth="300.0" spacing="15.0">
                    <children>
                        <Label text="Gestión de Paradas">
                            <font><Font name="Consolas Bold" size="24.0" /></font>
                        </Label>

                        <Label text="ID de la Parada:" />
                        <TextField fx:id="txtId"  />

                        <Label text="Nombre de la Parada:" />
                        <TextField fx:id="txtNombre" promptText="Ej: Monumento" />

                        <HBox spacing="10.0">
                            <children>
                                <Button fx:id="btnAgregar" mnemonicParsing="false" onAction="#agregarParada" prefWidth="145.0" style="-fx-background-color: #088395;" text="Agregar" textFill="WHITE">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>
                                <Button fx:id="btnEditar" mnemonicParsing="false" onAction="#editarParada" prefWidth="145.0" style="-fx-background-color: #f0ad4e;" text="Editar" textFill="WHITE">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>
                            </children>
                        </HBox>

                        <Button fx:id="btnEliminar" mnemonicParsing="false" onAction="#eliminarParada" prefWidth="300.0" style="-fx-background-color: #d9534f;" text="Eliminar Parada" textFill="WHITE">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#limpiarFormulario" prefWidth="300.0" text="Limpiar / Nueva Selección" />
                    </children>
                </VBox>

                <TableView fx:id="tablaParadas" prefHeight="500.0" prefWidth="450.0" HBox.hgrow="ALWAYS" >
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="100.0" text="ID" />
                        <TableColumn fx:id="colNombre" prefWidth="340.0" text="Nombre" />
                    </columns>
                </TableView>
            </children>
        </HBox>
    </children>
</AnchorPane>